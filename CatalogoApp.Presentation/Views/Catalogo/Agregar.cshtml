@model CatalogoApp.Domain.Models.Item

@{
    ViewData["Title"] = "Agregar videojuego";
}

<section class="formulario-container">
    <div class="formulario-card">
        <div class="formulario-header">
            <div class="formulario-icono">
                🎮
            </div>

            <div>
                <h1>Agregar videojuego</h1>
                <p>Registra un nuevo videojuego en tu catálogo.</p>
            </div>
        </div>

        <form asp-action="Agregar" method="post" class="formulario-videojuego">
            <div class="campo-formulario">
                <label asp-for="Titulo">Título</label>
                <input asp-for="Titulo" placeholder="Ejemplo: Halo Infinite" />
                <span asp-validation-for="Titulo" class="text-danger"></span>
            </div>

            <div class="campo-formulario">
                <label asp-for="Genero">Género</label>
                <input asp-for="Genero" placeholder="Ejemplo: Acción" />
                <span asp-validation-for="Genero" class="text-danger"></span>
            </div>

            <div class="campo-formulario">
                <label asp-for="Consola">Consola</label>
                <input asp-for="Consola" placeholder="Ejemplo: Xbox Series X" />
                <span asp-validation-for="Consola" class="text-danger"></span>
            </div>

            <div class="campo-formulario">
                <label asp-for="Ano">Año</label>
                <input asp-for="Ano" type="number" placeholder="Ejemplo: 2021" />
                <span asp-validation-for="Ano" class="text-danger"></span>
            </div>

            <div class="campo-formulario">
                <label asp-for="Descripcion">Descripción</label>
                <textarea asp-for="Descripcion" rows="4" placeholder="Escribe una breve descripción del videojuego"></textarea>
                <span asp-validation-for="Descripcion" class="text-danger"></span>
            </div>

            <div class="acciones-formulario">
                <button type="submit" class="btn-guardar">
                    Guardar videojuego
                </button>

                <a asp-action="Index" class="btn-cancelar">
                    Cancelar
                </a>
            </div>
        </form>
    </div>
</section>

@section Scripts {
    @{
        await Html.RenderPartialAsync("_ValidationScriptsPartial");
    }
}