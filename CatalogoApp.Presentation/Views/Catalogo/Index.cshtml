@model List<CatalogoApp.Domain.Models.Item>

@{
    ViewData["Title"] = "Catálogo de Videojuegos";
}

<section class="catalogo-hero">
    <div>
        <h1>Catálogo de Videojuegos</h1>
        <p>Explora tu colección de videojuegos por género, año y título.</p>
    </div>

    <a class="btn-agregar-videojuego" asp-action="Agregar">
        + Agregar videojuego
    </a>
</section>

<section class="filtros-genero">
    <span class="filtro-label">Filtrar por género:</span>

    <a class="filtro-link" asp-action="Index">
        Todos
    </a>

    @foreach (var gen in ViewBag.Generos as List<string>)
    {
        <a class="filtro-link" asp-action="Index" asp-route-genero="@gen">
            @gen
        </a>
    }
</section>

@if (Model == null || !Model.Any())
{
    <div class="catalogo-vacio">
        <h2>No hay videojuegos registrados</h2>
        <p>Agrega tu primer videojuego al catálogo.</p>

        <a class="btn-agregar-videojuego" asp-action="Agregar">
            Agregar videojuego
        </a>
    </div>
}
else
{
    <section class="videojuegos-grid">
        @foreach (var item in Model)
        {
            <article class="videojuego-card">
                <div class="videojuego-imagen">
                    🎮
                </div>

                <div class="videojuego-info">
                    <span class="videojuego-genero">@item.Genero</span>

                    <h2>@item.Titulo</h2>

                    <p>
                        <strong>Año:</strong> @item.Ano
                    </p>

                    <a class="btn-detalle" asp-action="Detalle" asp-route-id="@item.Id">
                        Ver detalles
                    </a>
                </div>
            </article>
        }
    </section>
}



